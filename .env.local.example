# ── KC Energy Advisors — Environment Variables ──────────────────────────────
# Copy this file to .env.local (local dev) or paste into Vercel → Settings →
# Environment Variables (production).  NEVER commit .env.local to git.

# ── 1. GHL Webhook URL ──────────────────────────────────────────────────────
# WHERE IT GOES:  app/api/submit-lead/route.ts → sendLeadToGHL()
# WHAT IT IS:     Your GoHighLevel Workflow 1 inbound webhook trigger URL
# HOW TO FIND IT: GHL → Automations → Your workflow → Trigger → Copy webhook URL
# ⚠️  This must be a services.leadconnectorhq.com URL — NEVER a Render/Python URL
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_LOCATION_ID/webhook-trigger/YOUR_TRIGGER_ID

# ── 2. Python Inbound URL ───────────────────────────────────────────────────
# WHERE IT GOES:  app/api/submit-lead/route.ts — fires for qualified website leads only
# WHAT IT IS:     michael_agent.py /webhook/inbound endpoint on Render
# WHEN IT FIRES:  Immediately after a visitor submits the qualify form and passes all checks
# ⚠️  This fires from Next.js code — NOT from GHL
PYTHON_INBOUND_URL=https://michael-agent-2uov.onrender.com/webhook/inbound

# ── 3. Python Booking-Followup URL ─────────────────────────────────────────
# WHERE IT GOES:  GHL Workflow — NOT in Next.js code
# WHAT IT IS:     michael_agent.py /webhook/booking-followup endpoint on Render
# WHEN IT FIRES:  After a lead books a calendar appointment (GHL "Appointment Created" trigger)
# HOW TO WIRE IT: GHL → Automations → New Workflow
#                   Trigger:  "Appointment Created"
#                   Action:   "Send HTTP Request"
#                   Method:   POST
#                   URL:      https://michael-agent-2uov.onrender.com/webhook/booking-followup
#                   Body:     { "contact_id": "{{contact.id}}", "phone": "{{contact.phone}}", "appointment_time": "{{appointment.start_time}}" }
# NOTE: Because the calendar is an <iframe>, Next.js cannot detect bookings.
#       This URL is a GHL configuration step — no code change required here.
PYTHON_BOOKING_FOLLOWUP_URL=https://michael-agent-2uov.onrender.com/webhook/booking-followup

# ── GHL Location ────────────────────────────────────────────────────────────
# GHL Location ID (Settings → Business Info)
GHL_LOCATION_ID=GzCNeSvcjSom5bMGtmt6

# ── GHL API Keys (two separate private integrations) ────────────────────────
#
# PREFERRED: set both specific keys so each integration uses its own scoped token.
# FALLBACK:  if a specific key is not set, the code falls back to GHL_API_KEY.
#            This means Vercel currently works with only GHL_API_KEY set — no
#            breakage until you are ready to split.
#
# GHL_LEAD_API_KEY — "KC Web Lead API" private integration
#   Used by: /api/submit-lead → upsertGHLContact, tagGHLContact
#   Needs scopes: contacts.write, contacts.readonly
GHL_LEAD_API_KEY=

# GHL_BOOKING_API_KEY — "KC Booking API (Clean)" private integration
#   Used by: /api/calendar-slots → getCalendarSlots
#            /api/book-appointment → createGHLAppointment
#   Needs scopes: calendars.readonly, calendars/events.write
GHL_BOOKING_API_KEY=

# GHL_API_KEY — legacy single key (fallback if specific keys above are blank)
#   Leave this set in Vercel until you have confirmed both specific keys work.
#   Once verified, you can clear this value.
GHL_API_KEY=pit-22cd3474-f6eb-4803-8fbf-89d8983ef74f

# GHL Calendar ID — the slug from your booking widget URL
# Example: https://api.leadconnectorhq.com/widget/booking/0fu9WuucPW0YhM0SEGf
#                                                                  ↑ this part
# Used by /api/calendar-slots and /api/book-appointment
# NEVER expose this with NEXT_PUBLIC_ — it's server-side only
GHL_CALENDAR_ID=0fu9WuucPW0YhM0SEGf

# ── GHL Assigned User ID ────────────────────────────────────────────────────
# WHO IT IS:    The GHL user (Michael) who owns the calendar and should receive
#               appointment notifications.
# WHY IT MATTERS: Without this, appointments land unassigned — Michael's
#               "Appointment Created" workflow may not trigger correctly.
# HOW TO FIND IT: GHL → Settings → Team Management → click Michael → copy the
#               user ID from the URL (e.g. /settings/team/abc123def456)
#               OR: GHL API → GET /users → find Michael's entry → copy "id"
# WHAT HAPPENS: If set, /api/book-appointment sends assignedUserId in the GHL
#               POST body so the appointment is attributed to Michael's account.
#               If unset, the appointment is still created but may be unassigned.
GHL_ASSIGNED_USER_ID=VEagWjM1WwxVlrX0ogjp

# ── GHL Custom Field IDs (workflow merge tags) ───────────────────────────────
# These IDs let the website write qualification data directly into GHL contact
# custom fields so your workflow merge tags resolve correctly:
#
#   {{contact.monthly_bill}}   → GHL_CF_MONTHLY_BILL
#   {{contact.roof_type}}      → GHL_CF_ROOF_TYPE
#   {{contact.owns_home}}      → GHL_CF_OWNS_HOME
#   {{contact.decision_stage}} → GHL_CF_DECISION_STAGE
#
# HOW TO FIND EACH ID:
#   GHL → Settings → Custom Fields → click the field name → look at the URL,
#   the ID is the last segment: /settings/custom-fields/{FIELD_ID}
#   OR open GHL API → GET /locations/{locationId}/customFields → find by "name"
#   field → copy the "id" value.
#
# If any of these are blank, that field is skipped in the contact upsert and
# Vercel logs will show: ⚠️ MISSING (set GHL_CF_*).
# The appointment will still book — only the merge tag will be empty in GHL.
GHL_CF_MONTHLY_BILL=
GHL_CF_ROOF_TYPE=
GHL_CF_OWNS_HOME=
GHL_CF_DECISION_STAGE=

# ── Internal SMS notification ────────────────────────────────────────────────
# WHO IT IS:    The phone number that receives an SMS after every successful booking.
#               This is Michael's number — for internal lead alerts only.
# FORMAT:       E.164 international format, e.g. +18165551234
# WHEN IT FIRES: Immediately after createGHLAppointment() succeeds (both initial
#               and retry paths). Sent via GHL Conversations API using GHL_API_KEY.
#               If unset, the notification is silently skipped.
# NOTE:         This is an outbound SMS sent through your GHL account. Ensure the
#               GHL_API_KEY has conversations.write scope.
INTERNAL_NOTIFICATION_PHONE=+1816XXXXXXX

# Optional: Secret token to authenticate calls between your API route and GHL
# Generate with: openssl rand -hex 32
LEAD_API_SECRET=

# ── Public vars (safe to expose to the browser) ─────────────────────────────
# Canonical site URL — used for OG images and CORS
NEXT_PUBLIC_SITE_URL=https://kcenergyadvisors.com

# GHL Location ID (browser-side — same value as GHL_LOCATION_ID)
NEXT_PUBLIC_LOCATION_ID=GzCNeSvcjSom5bMGtmt6

# GHL Calendar embed URL — placed on /thank-you page as an <iframe>
NEXT_PUBLIC_BOOKING_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/0fu9WuucPW0YhM0SEGf
