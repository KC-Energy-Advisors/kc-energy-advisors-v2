# ── KC Energy Advisors — Environment Variables ──────────────────────────────
# Copy this file to .env.local (local dev) or paste into Vercel → Settings →
# Environment Variables (production).  NEVER commit .env.local to git.

# ── 1. GHL Webhook URL ──────────────────────────────────────────────────────
# WHERE IT GOES:  app/api/submit-lead/route.ts → sendLeadToGHL()
# WHAT IT IS:     Your GoHighLevel Workflow 1 inbound webhook trigger URL
# HOW TO FIND IT: GHL → Automations → Your workflow → Trigger → Copy webhook URL
# ⚠️  This must be a services.leadconnectorhq.com URL — NEVER a Render/Python URL
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_LOCATION_ID/webhook-trigger/YOUR_TRIGGER_ID

# ── 2. Python Inbound URL ───────────────────────────────────────────────────
# WHERE IT GOES:  app/api/submit-lead/route.ts — fires for qualified website leads only
# WHAT IT IS:     michael_agent.py /webhook/inbound endpoint on Render
# WHEN IT FIRES:  Immediately after a visitor submits the qualify form and passes all checks
# ⚠️  This fires from Next.js code — NOT from GHL
PYTHON_INBOUND_URL=https://michael-agent-2uov.onrender.com/webhook/inbound

# ── 3. Python Booking-Followup URL ─────────────────────────────────────────
# WHERE IT GOES:  GHL Workflow — NOT in Next.js code
# WHAT IT IS:     michael_agent.py /webhook/booking-followup endpoint on Render
# WHEN IT FIRES:  After a lead books a calendar appointment (GHL "Appointment Created" trigger)
# HOW TO WIRE IT: GHL → Automations → New Workflow
#                   Trigger:  "Appointment Created"
#                   Action:   "Send HTTP Request"
#                   Method:   POST
#                   URL:      https://michael-agent-2uov.onrender.com/webhook/booking-followup
#                   Body:     { "contact_id": "{{contact.id}}", "phone": "{{contact.phone}}", "appointment_time": "{{appointment.start_time}}" }
# NOTE: Because the calendar is an <iframe>, Next.js cannot detect bookings.
#       This URL is a GHL configuration step — no code change required here.
PYTHON_BOOKING_FOLLOWUP_URL=https://michael-agent-2uov.onrender.com/webhook/booking-followup

# ── GHL Contact / Location ──────────────────────────────────────────────────
# GHL Location ID (Settings → Business Info)
GHL_LOCATION_ID=GzCNeSvcjSom5bMGtmt6

# GHL API Key (Settings → Integrations → API Keys)
GHL_API_KEY=pit-22cd3474-f6eb-4803-8fbf-89d8983ef74f

# Optional: Secret token to authenticate calls between your API route and GHL
# Generate with: openssl rand -hex 32
LEAD_API_SECRET=

# ── Public vars (safe to expose to the browser) ─────────────────────────────
# Canonical site URL — used for OG images and CORS
NEXT_PUBLIC_SITE_URL=https://kcenergyadvisors.com

# GHL Location ID (browser-side — same value as GHL_LOCATION_ID)
NEXT_PUBLIC_LOCATION_ID=GzCNeSvcjSom5bMGtmt6

# GHL Calendar embed URL — placed on /thank-you page as an <iframe>
NEXT_PUBLIC_BOOKING_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/0fu9WucPWOYhM0
